generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  passwordHash  String?
  googleId      String?
  username      String    @unique
  avatarUrl     String?
  rating        Int       @default(1200)
  gamesPlayed   Int       @default(0)
  wins          Int       @default(0)
  losses        Int       @default(0)
  draws         Int       @default(0)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  settings      Settings?
  gamesAsWhite  Game[]    @relation("WhitePlayer")
  gamesAsBlack  Game[]    @relation("BlackPlayer")
  friends       Friend[]  @relation("UserFriends")
  friendOf      Friend[]  @relation("FriendUsers")
  tournaments   TournamentParticipant[]
}

model Settings {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @unique @db.ObjectId
  user               User    @relation(fields: [userId], references: [id])
  cursorSensitivity  Float   @default(1.0)
  gestureSensitivity Float   @default(1.0)
  pinchThreshold     Float   @default(0.5)
  theme              String  @default("dark")
  boardTheme         String  @default("classic")
  pieceTheme         String  @default("classic")
  soundVolume        Float   @default(0.8)
}

model Game {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  whiteId       String?  @db.ObjectId
  blackId       String?  @db.ObjectId
  white         User?    @relation("WhitePlayer", fields: [whiteId], references: [id])
  black         User?    @relation("BlackPlayer", fields: [blackId], references: [id])
  status        String   // "ongoing", "completed", "drawn", "abandoned"
  winnerId      String?  @db.ObjectId
  pgn           String
  fen           String   @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Friend {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  friendId  String   @db.ObjectId
  status    String   // "pending", "accepted"
  user      User     @relation("UserFriends", fields: [userId], references: [id])
  friend    User     @relation("FriendUsers", fields: [friendId], references: [id])
}

model Tournament {
  id           String                  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  status       String                  // "waiting", "in_progress", "completed"
  creatorId    String                  @db.ObjectId
  winnerId     String?                 @db.ObjectId
  timeControl  String                  // e.g. "3|0", "5|0"
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  participants TournamentParticipant[]
}

model TournamentParticipant {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  tournamentId String      @db.ObjectId
  userId       String      @db.ObjectId
  status       String      // "active", "eliminated", "spectating", "winner"
  score        Int         @default(0)
  
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
}
